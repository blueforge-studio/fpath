{
  "name": "fpath",
  "version": "0.0.0",
  "private": true,
  "description": "File browser companion for Claude Code — quick file path discovery, tree navigation, and syntax-highlighted preview",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@fpath/desktop",
    "dev:marketing": "turbo run dev --filter=@fpath/marketing",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@fpath/desktop",
    "build:marketing": "turbo run build --filter=@fpath/marketing",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
