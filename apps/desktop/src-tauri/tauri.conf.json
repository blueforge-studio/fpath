{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/refs/heads/main/src/schemas/tauri-2.schema.json",
  "productName": "fpath",
  "version": "0.0.0",
  "identifier": "studio.blueforge.fpath",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "createUpdaterArtifacts": true
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "fpath",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400
      },
      {
        "label": "popup",
        "url": "index.html#popup",
        "title": "fpath quick search",
        "width": 640,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/blueforge-studio/fpath/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxRjc2N0UwNjE3MTEyNjQKUldSa0VuRmg0R2YzSWZjVEEzMHhrOUxFY2NrY28zaUhZN1BWV3IwZVM0ZmNaZnFzRUl0VGZKN2gK"
    }
  }
}
