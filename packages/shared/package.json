{
  "name": "@fpath/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared file tree logic, types, and path utilities for fpath",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./tree": "./src/tree.ts",
    "./path-utils": "./src/path-utils.ts",
    "./ignore": "./src/ignore.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  }
}
